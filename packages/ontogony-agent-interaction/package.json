{
  "name": "@ontogony/agent-interaction",
  "private": true,
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Ontogony agent interaction spine types and AG-UI compatibility adapter (protocol-neutral mechanics).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ag-ui": {
      "types": "./dist/ag-ui.d.ts",
      "import": "./dist/ag-ui.js",
      "require": "./dist/ag-ui.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.5"
  }
}
