#
# ENV-COMPOSE-001
# Development-only Docker local working system placeholders.
# Do not place real provider keys or production secrets in this file.
#

# Shared runtime
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Optional Docker build CA injection for local TLS interception environments.
# Leave empty by default. start-local-working-system.ps1 can auto-populate this
# at runtime from Windows trust store when NuGet TLS probe fails in container.
DOCKER_EXTRA_CA_CERT_BASE64=

# Host port mappings
# Default 55433 avoids collision with a local Postgres on 5432. Override if that port is taken.
POSTGRES_HOST_PORT=55433
KANON_HOST_PORT=5081
CONEXUS_HOST_PORT=5082
ALLAGMA_HOST_PORT=5083
FRONTEND_HOST_PORT=5175

# Frontend Docker build provenance (DOCKER-LOCAL-VERIFY-001).
# start-local-working-system.ps1 -Build sets these from ontogony-frontend git HEAD when unset.
FRONTEND_VITE_GIT_SHA=
FRONTEND_VITE_APP_VERSION=
FRONTEND_VITE_BUILD_TIME=

# Browser CORS (Development / Docker-local only — not production readiness)
FRONTEND_CORS_ORIGIN_LOCALHOST=http://localhost:5175
FRONTEND_CORS_ORIGIN_LOOPBACK=http://127.0.0.1:5175
KANON_CORS_ENABLED=true
CONEXUS_CORS_ENABLED=true
ALLAGMA_CORS_ENABLED=true

# Postgres bootstrap
POSTGRES_USER=ontogony_admin
POSTGRES_PASSWORD=ontogony_admin_pw
POSTGRES_DB=postgres

# Service Postgres connection strings
KANON_POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=kanon_local;Username=kanon_local;Password=kanon_local_pw
CONEXUS_POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=conexus_local;Username=conexus_local;Password=conexus_local_pw
ALLAGMA_POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=allagma_local;Username=allagma_local;Password=allagma_local_pw

# Service behavior
KANON_PERSISTENCE_MODE=Postgres
KANON_APPLY_MIGRATIONS_ON_STARTUP=true
ALLAGMA_PERSISTENCE_MODE=Postgres
ALLAGMA_MANUAL_EVAL_WRITE_ENABLED=true

# Internal container-to-container URLs
KANON_INTERNAL_BASE_URL=http://kanon-api:8080
CONEXUS_INTERNAL_BASE_URL=http://conexus-api:8080

# Development API keys/tokens (placeholders only)
CONEXUS_DEV_PROJECT_API_KEY=cx-dev-key-change-me
CONEXUS_ADMIN_API_KEY=cx-conexus-admin-dev
CONEXUS_PROJECT_API_KEY_FOR_ALLAGMA=cx-dev-key-change-me
ALLAGMA_SERVICE_TOKEN=allagma-dev-service-token-change-in-production
KANON_SERVICE_TOKEN=kanon-dev-service-token-change-in-production

# Frontend build-time base URLs (browser uses host ports, not container DNS)
FRONTEND_VITE_KANON_BASE_URL=http://localhost:5081
FRONTEND_VITE_KANON_ONTOLOGY_ID=gaming-core
FRONTEND_VITE_KANON_ONTOLOGY_VERSION_ID=gaming-core@0.1.0
# Browser Kanon actor headers (build-time defaults for fresh operator profiles)
FRONTEND_VITE_KANON_DEFAULT_ACTOR_ID=local-operator
FRONTEND_VITE_KANON_DEFAULT_ACTOR_ROLES=Auditor,ProvenanceReader
FRONTEND_VITE_CONEXUS_BASE_URL=http://localhost:5082
FRONTEND_VITE_ALLAGMA_BASE_URL=http://localhost:5083
# Browser-only operator route gate (not backend auth); unlocks console on first load
FRONTEND_VITE_OPERATOR_SESSION_TOKEN=docker-local-operator-session

# --- Real provider validation (RP-001 policy; RP-002 implements gate) — disabled by default ---
# Do not commit real provider API keys. Fake provider remains default for compose/bootstrap.
CONEXUS_PROVIDER_OPENAI_API_KEY=
CONEXUS_REAL_PROVIDER_ENABLED=false
CONEXUS_REAL_PROVIDER_NAME=openai
CONEXUS_REAL_PROVIDER_MODEL=gpt-4o-mini
CONEXUS_REAL_PROVIDER_MAX_CALLS=3
CONEXUS_REAL_PROVIDER_MAX_OUTPUT_TOKENS=256
