{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "allagma-sandbox-execute-events-v1.schema.json",
  "title": "Allagma Sandbox Execute Events",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/started"
    },
    {
      "$ref": "#/$defs/completed"
    },
    {
      "$ref": "#/$defs/blocked"
    },
    {
      "$ref": "#/$defs/failed"
    },
    {
      "$ref": "#/$defs/replaySkipped"
    }
  ],
  "$defs": {
    "basePayload": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "toolIntentId": {
          "type": "string"
        }
      },
      "required": [
        "runId",
        "toolIntentId"
      ],
      "additionalProperties": true
    },
    "started": {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "Allagma.SandboxExecuteStarted"
        },
        "payload": {
          "allOf": [
            {
              "$ref": "#/$defs/basePayload"
            }
          ],
          "required": [
            "runId",
            "toolIntentId",
            "sideEffectId",
            "kanonDecisionId",
            "registryVersion",
            "effectFingerprint",
            "sandboxRoot"
          ]
        }
      },
      "required": [
        "eventType",
        "payload"
      ]
    },
    "completed": {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "Allagma.SandboxExecuteCompleted"
        },
        "payload": {
          "allOf": [
            {
              "$ref": "#/$defs/basePayload"
            }
          ],
          "required": [
            "runId",
            "toolIntentId",
            "sideEffectId",
            "effectFingerprint",
            "relativePath",
            "executorRef",
            "externalRefType"
          ]
        }
      },
      "required": [
        "eventType",
        "payload"
      ]
    },
    "blocked": {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "Allagma.SandboxExecuteBlocked"
        },
        "payload": {
          "allOf": [
            {
              "$ref": "#/$defs/basePayload"
            }
          ],
          "required": [
            "runId",
            "toolIntentId",
            "reason"
          ]
        }
      },
      "required": [
        "eventType",
        "payload"
      ]
    },
    "failed": {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "Allagma.SandboxExecuteFailed"
        },
        "payload": {
          "allOf": [
            {
              "$ref": "#/$defs/basePayload"
            }
          ],
          "required": [
            "runId",
            "toolIntentId",
            "sideEffectId",
            "failureClass",
            "failureMessage"
          ]
        }
      },
      "required": [
        "eventType",
        "payload"
      ]
    },
    "replaySkipped": {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "Allagma.SandboxExecuteReplaySkipped"
        },
        "payload": {
          "allOf": [
            {
              "$ref": "#/$defs/basePayload"
            }
          ],
          "required": [
            "runId",
            "toolIntentId",
            "sideEffectId",
            "effectFingerprint"
          ]
        }
      },
      "required": [
        "eventType",
        "payload"
      ]
    }
  }
}
