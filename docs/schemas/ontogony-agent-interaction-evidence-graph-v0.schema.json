{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.dev/schemas/ontogony-agent-interaction-evidence-graph-v0.schema.json",
  "title": "Ontogony agent interaction evidence graph result v0",
  "description": "Client-side result of resolveAgentInteractionEvidenceGraph — event-scoped Evidence Spine bridge for AG-UI workbench.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "eventId",
    "eventType",
    "mode",
    "operatorLinks",
    "nodes",
    "unresolved"
  ],
  "properties": {
    "schema": {
      "const": "ontogony-agent-interaction-evidence-graph-v0"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["live", "links-only", "fixture"]
    },
    "anchor": {
      "$ref": "#/$defs/evidenceAnchor"
    },
    "spineWorkbenchHref": {
      "type": "string",
      "minLength": 1
    },
    "operatorLinks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operatorLink"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceNode"
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolvedId"
      }
    }
  },
  "$defs": {
    "evidenceAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "raw", "source", "eventFamily"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "raw": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": ["event.evidence", "event.ids", "event.family"]
        },
        "eventFamily": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operatorLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "label"],
      "properties": {
        "service": {
          "enum": [
            "allagma",
            "kanon",
            "conexus",
            "ontogony-platform",
            "ontogony-frontend",
            "external"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string"
        },
        "identifierKind": {
          "type": "string"
        },
        "identifierValue": {
          "type": "string"
        },
        "missingReasonCode": {
          "type": "string"
        }
      }
    },
    "evidenceNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "kind", "service", "label", "pageLinks"],
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "pageLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pageLink"
          }
        }
      }
    },
    "pageLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href", "present"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "present": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "unresolvedId": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "reason"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "enum": [
            "not_present_on_event",
            "service_unconfigured",
            "service_unreachable",
            "ambiguous_identifier",
            "route_not_exposed"
          ]
        }
      }
    }
  }
}
