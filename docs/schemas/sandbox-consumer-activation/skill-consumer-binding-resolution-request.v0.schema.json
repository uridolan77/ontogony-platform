{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.local/schemas/skill-consumer-binding-resolution-request.v0.json",
  "title": "SkillConsumerBindingResolutionRequestV0",
  "type": "object",
  "required": ["consumerId", "targetEnvironment", "skillArtifactId"],
  "properties": {
    "consumerId": { "type": "string", "minLength": 1 },
    "targetEnvironment": {
      "type": "string",
      "enum": ["sandbox", "local-demo", "fixture-only"]
    },
    "skillArtifactId": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
