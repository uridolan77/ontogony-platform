{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "allagma-eval-ci-summary-v1",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "profileId",
    "verdict",
    "cases",
    "safety"
  ],
  "properties": {
    "schema": {
      "const": "allagma-eval-ci-summary-v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "profileId": {
      "type": "string"
    },
    "datasetId": {
      "type": [
        "string",
        "null"
      ]
    },
    "datasetVersion": {
      "type": [
        "string",
        "null"
      ]
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "WARN"
      ]
    },
    "cases": {
      "type": "array"
    },
    "safety": {
      "type": "object"
    }
  }
}
