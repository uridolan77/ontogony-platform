{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ontogony-full-sanity-report-v1",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "verdict",
    "services",
    "scenario",
    "evidence",
    "safety"
  ],
  "properties": {
    "schema": {
      "const": "ontogony-full-sanity-report-v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "INCONCLUSIVE"
      ]
    },
    "services": {
      "type": "array"
    },
    "scenario": {
      "type": "object"
    },
    "evidence": {
      "type": "object"
    },
    "safety": {
      "type": "object"
    },
    "knownLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
