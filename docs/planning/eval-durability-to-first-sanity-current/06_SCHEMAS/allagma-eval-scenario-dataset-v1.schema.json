{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "allagma-eval-scenario-dataset-v1",
  "type": "object",
  "required": [
    "schema",
    "datasetId",
    "version",
    "fixture",
    "defaultEvaluationProfileId",
    "suite",
    "caseFiles"
  ],
  "properties": {
    "schema": { "const": "allagma-eval-scenario-dataset-v1" },
    "datasetId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "fixture": { "const": true },
    "defaultEvaluationProfileId": { "type": "string", "minLength": 1 },
    "suite": {
      "type": "object",
      "required": ["replayKindOrder"],
      "properties": {
        "replayKindOrder": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "caseFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "expectedFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "baselineFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "labelFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
