{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.dev/schemas/ontogony-agent-interaction-event-v0.schema.json",
  "title": "Ontogony Agent Interaction Event v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "eventId",
    "type",
    "timestamp",
    "source",
    "ids",
    "payload"
  ],
  "properties": {
    "schema": {
      "const": "ontogony-agent-interaction-event-v0"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "RUN_STARTED",
        "RUN_FINISHED",
        "RUN_ERROR",
        "RUN_CANCELLED",
        "RUN_RETRIED",
        "RUN_REPLAYED",
        "STEP_STARTED",
        "STEP_PROGRESS",
        "STEP_FINISHED",
        "STEP_ERROR",
        "MESSAGE_STARTED",
        "MESSAGE_DELTA",
        "MESSAGE_FINISHED",
        "MESSAGE_SNAPSHOT",
        "TOOL_CALL_STARTED",
        "TOOL_CALL_ARGS_DELTA",
        "TOOL_CALL_READY",
        "TOOL_CALL_RESULT",
        "TOOL_CALL_ERROR",
        "STATE_SNAPSHOT",
        "STATE_DELTA",
        "INTERRUPT_CREATED",
        "INTERRUPT_EXPIRED",
        "INTERRUPT_CANCELLED",
        "INTERRUPT_RESOLVED",
        "RESUME_SUBMITTED",
        "RESUME_REJECTED",
        "EVIDENCE_NODE_ADDED",
        "EVIDENCE_EDGE_ADDED",
        "EVIDENCE_SOURCE_ATTEMPTED",
        "EVIDENCE_LINK_ADDED",
        "EVIDENCE_GRAPH_SNAPSHOT",
        "DECISION_RECORDED",
        "DECISION_PROVENANCE_LINKED",
        "HUMAN_GATE_OPENED",
        "HUMAN_GATE_CHECKED",
        "HUMAN_GATE_RESOLVED",
        "MODEL_CALL_STARTED",
        "MODEL_CALL_ROUTE_DECIDED",
        "MODEL_CALL_PROVIDER_ATTEMPTED",
        "MODEL_CALL_COMPLETED",
        "MODEL_CALL_FAILED",
        "USAGE_COST_RECORDED",
        "UI_INTENT_PROPOSED",
        "UI_INTENT_ACCEPTED",
        "UI_INTENT_REJECTED",
        "UI_INTENT_RENDERED",
        "CUSTOM"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "allagma",
        "kanon",
        "conexus",
        "ontogony-frontend",
        "ontogony-ui",
        "ontogony-platform",
        "adapter",
        "fixture"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warning",
        "error"
      ]
    },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threadId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "parentRunId": {
          "type": "string"
        },
        "stepId": {
          "type": "string"
        },
        "operationId": {
          "type": "string"
        },
        "traceId": {
          "type": "string"
        },
        "correlationId": {
          "type": "string"
        },
        "modelCallId": {
          "type": "string"
        },
        "routeDecisionId": {
          "type": "string"
        },
        "kanonDecisionId": {
          "type": "string"
        },
        "planningDecisionId": {
          "type": "string"
        },
        "humanGateId": {
          "type": "string"
        },
        "evidenceNodeId": {
          "type": "string"
        },
        "evidenceEdgeId": {
          "type": "string"
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "containsRedactedFields": {
          "type": "boolean"
        },
        "redactionReasonCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service",
          "label"
        ],
        "properties": {
          "service": {
            "type": "string",
            "enum": [
              "allagma",
              "kanon",
              "conexus",
              "ontogony-platform",
              "ontogony-frontend",
              "external"
            ]
          },
          "label": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "identifierKind": {
            "type": "string"
          },
          "identifierValue": {
            "type": "string"
          },
          "missingReasonCode": {
            "type": "string"
          }
        }
      }
    },
    "payload": {}
  }
}
