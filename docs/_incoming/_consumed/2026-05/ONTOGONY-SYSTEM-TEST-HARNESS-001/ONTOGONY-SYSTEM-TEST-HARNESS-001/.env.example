# ONTOGONY-SYSTEM-TEST-HARNESS-001 environment

# Base URLs. Adjust ports to match your local stack.
ONTOGONY_PLATFORM_BASE_URL=http://localhost:5080
KANON_BASE_URL=http://localhost:5081
CONEXUS_BASE_URL=http://localhost:5082
ALLAGMA_BASE_URL=http://localhost:5083
METABOLE_BASE_URL=http://localhost:5084
AISTHESIS_BASE_URL=http://localhost:5085
ONTOGONY_FRONTEND_BASE_URL=http://localhost:5173

# Auth placeholders. Never commit real secrets.
ALLAGMA_SERVICE_TOKEN=allagma-dev-service-token-change-in-production
KANON_SERVICE_TOKEN=kanon-dev-service-token-change-in-production
CONEXUS_PROJECT_API_KEY=cx-dev-key-change-me
CONEXUS_ADMIN_API_KEY=cx-conexus-admin-dev
METABOLE_SERVICE_TOKEN=dev-metabole-service-token
AISTHESIS_SERVICE_TOKEN=dev-aisthesis-service-token

# Correlation identity used by automated tests.
ONTOGONY_TEST_ACTOR_ID=system-test-harness
ONTOGONY_TEST_ACTOR_TYPE=automation
ONTOGONY_TEST_ACTOR_ROLES=tester,operator,admin

# Evidence output.
ONTOGONY_EVIDENCE_DIR=./evidence/local

# Run categories.
RUN_DESTRUCTIVE_TESTS=false
RUN_LOAD_TESTS=false
RUN_RESTART_TESTS=false
RUN_UI_TESTS=false
RUN_EXTERNAL_PROVIDER_TESTS=false
