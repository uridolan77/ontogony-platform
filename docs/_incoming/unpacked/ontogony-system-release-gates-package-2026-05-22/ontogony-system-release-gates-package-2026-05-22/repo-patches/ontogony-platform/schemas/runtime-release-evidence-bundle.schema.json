{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.local/schemas/runtime-release-evidence-bundle.schema.json",
  "title": "Ontogony runtime release evidence bundle",
  "type": "object",
  "required": [
    "schema",
    "releaseId",
    "mode",
    "startedAtUtc",
    "completedAtUtc",
    "verdict",
    "runtimeLock",
    "repositories",
    "repoGates",
    "packageMode",
    "systemCohesion",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "const": "ontogony-runtime-release-evidence-v1"
    },
    "releaseId": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "Locked",
        "ExpectedRefs",
        "CurrentWorkspace"
      ]
    },
    "startedAtUtc": {
      "type": "string"
    },
    "completedAtUtc": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "INCONCLUSIVE",
        "DRIFT_ONLY"
      ]
    },
    "runtimeLock": {
      "type": "object"
    },
    "repositories": {
      "type": "object",
      "required": [
        "ontogony-platform",
        "kanon-dotnet",
        "conexus-dotnet",
        "allagma-dotnet"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "expectedRef",
          "lockedCommit",
          "actualCommit",
          "verdict"
        ],
        "properties": {
          "expectedRef": {
            "type": "string"
          },
          "lockedCommit": {
            "type": "string"
          },
          "actualCommit": {
            "type": "string"
          },
          "verdict": {
            "enum": [
              "PASS",
              "FAIL",
              "DRIFT"
            ]
          }
        }
      }
    },
    "repoGates": {
      "type": "object"
    },
    "packageMode": {
      "type": "object"
    },
    "systemCohesion": {
      "type": "object"
    },
    "capacityBaseline": {
      "type": [
        "object",
        "null"
      ]
    },
    "restartSurvival": {
      "type": [
        "object",
        "null"
      ]
    },
    "streamingSmoke": {
      "type": [
        "object",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
