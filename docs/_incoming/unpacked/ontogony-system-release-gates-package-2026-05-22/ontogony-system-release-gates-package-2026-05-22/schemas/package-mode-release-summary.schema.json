{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.local/schemas/package-mode-release-summary.schema.json",
  "title": "Ontogony package-mode release summary",
  "type": "object",
  "required": [
    "schema",
    "verdict",
    "startedAtUtc",
    "completedAtUtc",
    "packages",
    "restore",
    "build",
    "test",
    "noSiblingReferenceAssertion"
  ],
  "properties": {
    "schema": {
      "const": "ontogony-package-mode-release-summary-v1"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "INCONCLUSIVE"
      ]
    },
    "startedAtUtc": {
      "type": "string"
    },
    "completedAtUtc": {
      "type": "string"
    },
    "runtimeLockBaseline": {
      "type": "string"
    },
    "feedDirectory": {
      "type": "string"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "version"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "restore": {
      "type": "object"
    },
    "build": {
      "type": "object"
    },
    "test": {
      "type": "object"
    },
    "noSiblingReferenceAssertion": {
      "type": "object"
    }
  }
}
