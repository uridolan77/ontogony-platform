{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.dev/schemas/ontogony-cross-service-error-envelope-v1.schema.json",
  "title": "OntogonyCrossServiceErrorEnvelopeV1",
  "type": "object",
  "required": ["code", "message", "system"],
  "additionalProperties": false,
  "properties": {
    "code": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z0-9_.]+$"
    },
    "message": { "type": "string", "minLength": 1 },
    "system": {
      "type": "string",
      "enum": ["platform", "conexus", "kanon", "allagma", "metabole", "aisthesis"]
    },
    "traceId": { "type": "string", "minLength": 1 },
    "detail": { "type": "string" }
  }
}
