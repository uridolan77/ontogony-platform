{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Topology Selection",
  "type": "object",
  "required": [
    "topologySelectionId",
    "runId",
    "selectedTopology",
    "selectorVersion"
  ],
  "properties": {
    "topologySelectionId": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "selectedTopology": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "requiresKanonAuthorization": {
      "type": "boolean"
    },
    "selectorVersion": {
      "type": "string"
    },
    "classification": {
      "type": "string"
    },
    "riskLevel": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}