{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conexus Route Decision",
  "type": "object",
  "required": [
    "routeDecisionId",
    "requestId",
    "requestedModelAlias",
    "providerKey",
    "providerModel"
  ],
  "properties": {
    "routeDecisionId": {
      "type": "string"
    },
    "requestId": {
      "type": "string"
    },
    "traceId": {
      "type": [
        "string",
        "null"
      ]
    },
    "projectId": {
      "type": [
        "string",
        "null"
      ]
    },
    "requestedModelAlias": {
      "type": "string"
    },
    "resolvedModelAlias": {
      "type": "string"
    },
    "providerKey": {
      "type": "string"
    },
    "providerModel": {
      "type": "string"
    },
    "fallbackChain": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "priceCatalogVersion": {
      "type": [
        "string",
        "null"
      ]
    },
    "capabilityProfileVersion": {
      "type": [
        "string",
        "null"
      ]
    },
    "constraintsApplied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selectionReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}