{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ontogony Eval Run Summary",
  "type": "object",
  "required": [
    "schemaVersion",
    "evaluationRunId",
    "generatedAtUtc",
    "verdict",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "const": "eval-summary.v0"
    },
    "evaluationRunId": {
      "type": "string"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "degraded"
      ]
    },
    "qualityScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenarioResult"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "scenarioResult": {
      "type": "object",
      "required": [
        "scenarioId",
        "verdict",
        "runId",
        "scores"
      ],
      "properties": {
        "scenarioId": {
          "type": "string"
        },
        "verdict": {
          "enum": [
            "pass",
            "fail",
            "degraded",
            "skipped"
          ]
        },
        "runId": {
          "type": "string"
        },
        "traceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "taskClassification": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedTopology": {
          "type": [
            "string",
            "null"
          ]
        },
        "planningDecisionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "topologyPolicyDecisionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "routeDecisionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "modelCallId": {
          "type": [
            "string",
            "null"
          ]
        },
        "scores": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/score"
          }
        }
      }
    },
    "score": {
      "type": "object",
      "required": [
        "metricName",
        "passed"
      ],
      "properties": {
        "metricName": {
          "type": "string"
        },
        "score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "threshold": {
          "type": [
            "number",
            "null"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}