      "envelope": {
        "code": "validation.failed",
        "message": "Invalid field.",
        "system": "allagma",
        "downstreamSystem": "kanon",
        "retryable": false
      },
      "expectedTaxonomy": "validation_failed"
    },
    {
      "id": "kanon-404-not-found",
      "sourceSystem": "kanon",
