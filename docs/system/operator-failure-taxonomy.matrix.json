{
  "schema": "ontogony-operator-failure-taxonomy-v1",
  "baseline": "SYSTEM-ALPHA-006",
  "sprint": "SYS-TIGHT-006",
  "contractDocument": "docs/operators/SYSTEM_OPERATOR_FAILURE_TAXONOMY_CONTRACT.md",
  "crossServiceEnvelopeContract": "allagma-dotnet/docs/integrations/CROSS_SERVICE_ERROR_CONTRACT.md",
  "implementation": {
    "platformAdapter": "src/Ontogony.Errors/OperatorFailureTaxonomyAdapter.cs",
    "frontendAdapterModule": "ontogony-frontend/src/system/errors/operatorFailureTaxonomy.ts",
    "frontendBannerModule": "ontogony-frontend/src/system/errors/OperatorFailureBanner.tsx"
  },
  "wireShapes": {
    "allagma": "CrossServiceErrorEnvelope",
    "kanon": "Ontogony.ApiError",
    "conexus": "OpenAI.error"
  },
  "requiredTaxonomyKinds": [
    "auth_failed",
    "forbidden",
    "validation_failed",
    "not_found",
    "conflict",
    "idempotency_conflict",
    "downstream_unavailable",
    "provider_failed_retryable",
    "provider_failed_terminal",
    "quota_exceeded",
    "timeout",
    "unknown"
  ],
  "representativeMappings": [
    {
      "id": "kanon-401-auth",
      "sourceSystem": "kanon",
      "wireShape": "Ontogony.ApiError",
      "envelope": {
        "code": "auth.missing",
        "message": "Kanon rejected credentials.",
        "system": "allagma",
        "downstreamSystem": "kanon",
        "retryable": false
      },
      "expectedTaxonomy": "auth_failed"
    },
    {
      "id": "kanon-403-forbidden",
      "sourceSystem": "kanon",
      "wireShape": "Ontogony.ApiError",
      "envelope": {
        "code": "auth.forbidden",
