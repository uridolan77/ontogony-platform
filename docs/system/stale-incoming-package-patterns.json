{
  "schema": "ontogony-stale-incoming-package-patterns-v1",
  "currentBaseline": "SYSTEM-ALPHA-006",
  "reconciliationFileSets": [
    {
      "label": "CURRENT_BASELINE",
      "anyOf": ["CURRENT_BASELINE.md", "01_CURRENT_STATE_ASSESSMENT.md"]
    },
    {
      "label": "MOVING_MAIN_DELTA",
      "anyOf": ["MOVING_MAIN_DELTA.md", "02_MOVING_MAIN_DELTA.md"]
    },
    {
      "label": "SUPERSEDED_ITEMS",
      "anyOf": ["SUPERSEDED_ITEMS.md", "08_SUPERSEDED_ITEMS.md"]
    }
  ],
  "quarantineMarkerFile": "STALE_PACKAGE_QUARANTINE.json",
  "scanExtensions": [".md", ".txt", ".json", ".csv"],
  "exemptRelativePaths": [
    "08_SUPERSEDED_ITEMS.md",
    "SUPERSEDED_ITEMS.md",
    "INTAKE_STATUS.md",
    "00_EXECUTIVE_BRIEF.md",
    "01_CURRENT_STATE_ASSESSMENT.md",
    "02_MOVING_MAIN_DELTA.md",
    "06_VERIFICATION_CHECKLIST.md",
    "issue-cards/SYS-STALE-PACKAGE-GUARD-001.md",
    "issue-cards/SYS-OBS-004A.md",
    "issue-cards/SYS-LOCK-006.md",
    "issue-cards/SYS-EVIDENCE-INDEX-006.md",
    "source-notes/",
    "scripts/validate-incoming-package.ps1",
    "scripts/validate-stale-incoming-package.ps1",
    "data/refined_backlog.json",
    "data/refined_backlog.csv",
    "05_ACCEPTANCE_MATRIX.md",
    "03_REFINED_BACKLOG.md"
  ],
  "patterns": [
    {
      "id": "obsolete-agentor",
      "regex": "\\bAgentor\\b",
      "description": "Legacy Agentor product naming"
    },
    {
      "id": "stale-alpha004-pending-baseline",
      "regex": "(runtime baseline promotion|baseline lock pending|remains pending under)[^`\\n]{0,48}SYSTEM-ALPHA-004",
      "description": "Treats Alpha-004 as the pending cut baseline (superseded by Alpha-005/006)"
    },
    {
      "id": "stale-alpha004-cut-target",
      "regex": "(lock (is cut|updated) (only )?to|Set baseline to|baseline to) `?SYSTEM-ALPHA-004`?",
      "description": "Plans an Alpha-004 lock cut as the next baseline"
    },
    {
      "id": "system-production-ready-claim",
      "regex": "(?i)\\bSystem production ready\\b",
      "description": "Overclaims system production readiness"
    },
    {
      "id": "production-readiness-claim",
      "regex": "(?i)\\bproduction[- ]ready\\b|\\bproduction readiness\\b",
      "unlessLineRegex": "(?i)(not\\s+production|not claimed|non[- ]?claim|does not claim|no production readiness|without reconciliation)",
      "description": "Production readiness claim (exempt when explicitly negated on same line)"
    },
    {
      "id": "closed-b013-open-claim",
      "regex": "(?i)B-013.*(open|quarantine|blocked|missing|not cleared)",
      "description": "Reopens cleared Evidence Spine B-013"
    },
    {
      "id": "closed-b012-open-claim",
      "regex": "(?i)B-012[^.\\n]{0,60}\\b(open|quarantined|blocked|missing)\\b",
      "unlessLineRegex": "(?i)(close B-012|closes B-012|SYS-OBS-004A|cleared|not claimed|non[- ]?claim)",
      "description": "Reopens cleared observability B-012 without cleared context"
    },
    {
      "id": "hardcoded-old-allagma-model",
      "regex": "(?i)Allagma.*hard-?codes.*gpt-4o-mini|Model\\s*=\\s*\"gpt-4o-mini\"",
      "description": "Stale Allagma hard-coded model claim (implemented via catalog)"
    },
    {
      "id": "obsolete-kanon-v1-route",
      "regex": "MapGroup\\(\"/ontology/v1\"\\)|/ontology/v1/",
      "description": "Obsolete Kanon v1 route prefix (v0 until graduation)"
    },
    {
      "id": "obsolete-allagma-v1-route",
      "regex": "MapGroup\\(\"/allagma/v1\"\\)|/allagma/v0/runs/v1",
      "description": "Obsolete or non-canonical Allagma route prefix"
    }
  ],
  "reconciliationPackages": [
    {
      "relativePath": "Ontogony_System_Protocols_Delta_ALPHA005_2026-05-20",
      "requireReconciliationFiles": true,
      "maxNonExemptFindings": 0
    }
  ],
  "quarantinedLegacyPackages": [
    {
      "relativePath": "curated-review-package/ontogony_curated_review_package",
      "quarantineMarkerRelativePath": "curated-review-package/STALE_PACKAGE_QUARANTINE.json",
      "minimumStaleFindings": 4
    },
    {
      "relativePath": "ontogony-next-development-phase-package/ontogony-next-development-phase-package",
      "quarantineMarkerRelativePath": "ontogony-next-development-phase-package/STALE_PACKAGE_QUARANTINE.json",
      "minimumStaleFindings": 5
    },
    {
      "relativePath": "Ontogony-Cross-Service-Evidence-Spine-Package-v1",
      "quarantineMarkerRelativePath": "Ontogony-Cross-Service-Evidence-Spine-Package-v1/STALE_PACKAGE_QUARANTINE.json",
      "minimumStaleFindings": 0
    }
  ]
}
