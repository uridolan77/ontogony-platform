{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ontogony.local/mechanics/v1/error-envelope.schema.json",
  "title": "Ontogony Error Envelope",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "code": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "correlationId": {
      "type": "string"
    },
    "details": {
      "type": [
        "object",
        "null"
      ]
    },
    "retryAfterSeconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "redaction": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "required": [
    "code",
    "message"
  ]
}
