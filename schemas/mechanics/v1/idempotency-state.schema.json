{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ontogony.local/mechanics/v1/idempotency-state.schema.json",
  "title": "Ontogony Idempotency State",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "key": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "requestFingerprint": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "reserved",
        "running",
        "completed",
        "failed",
        "expired",
        "conflict"
      ]
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "responseRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "errorRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "key",
    "operation",
    "requestFingerprint",
    "status"
  ]
}
