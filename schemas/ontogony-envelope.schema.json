{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.net/schemas/ontogony-envelope.schema.json",
  "title": "OntogonyEnvelope",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "source",
    "occurredAt",
    "traceId",
    "protocol",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string"
    },
    "spanId": {
      "type": [
        "string",
        "null"
      ]
    },
    "parentSpanId": {
      "type": [
        "string",
        "null"
      ]
    },
    "tenantId": {
      "type": [
        "string",
        "null"
      ]
    },
    "workspaceId": {
      "type": [
        "string",
        "null"
      ]
    },
    "projectId": {
      "type": [
        "string",
        "null"
      ]
    },
    "actorId": {
      "type": [
        "string",
        "null"
      ]
    },
    "sessionId": {
      "type": [
        "string",
        "null"
      ]
    },
    "protocol": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "payloadHash": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "payload": {}
  },
  "additionalProperties": false
}