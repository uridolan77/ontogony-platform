{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontogony.dev/schemas/ontogony-envelope.schema.json",
  "title": "OntogonyEnvelope (serialized JSON)",
  "description": "Mechanical JSON shape for OntogonyEnvelope<TPayload> as produced by System.Text.Json. Payload is schema-specific and not constrained here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "EventId",
    "EventType",
    "Source",
    "OccurredAt",
    "TraceId",
    "Protocol",
    "SchemaVersion",
    "Payload"
  ],
  "properties": {
    "EventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[a-zA-Z0-9:_./-]+$"
    },
    "EventType": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}\\.[a-z0-9][a-z0-9-]{0,63}\\.[a-z0-9][a-z0-9-]{0,63}$"
    },
    "Source": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute URI only (including custom schemes such as mcp://). Relative paths are not accepted."
    },
    "OccurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "TraceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[a-zA-Z0-9:_./-]+$"
    },
    "SpanId": { "type": "string" },
    "ParentSpanId": { "type": "string" },
    "TenantId": { "type": "string" },
    "WorkspaceId": { "type": "string" },
    "ProjectId": { "type": "string" },
    "ActorId": { "type": "string" },
    "SessionId": { "type": "string" },
    "Protocol": {
      "type": "string",
      "enum": [
        "ag-ui",
        "generic-json",
        "mcp",
        "a2a",
        "otel",
        "cloudevents",
        "conexus",
        "agentor",
        "athanor",
        "vercel-ai-sdk",
        "openai-agents",
        "langgraph"
      ]
    },
    "ProtocolId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9:_./-]+$"
    },
    "AuthorityMode": {
      "type": "string",
      "enum": [
        "authoritative",
        "draft_only",
        "simulation_only",
        "blocked",
        "local_only",
        "observational",
        "gateway",
        "unknown"
      ]
    },
    "SideEffectLevel": {
      "type": "string",
      "enum": [
        "none",
        "read_only",
        "evidence_record",
        "semantic_decision",
        "run_state_transition",
        "model_call",
        "local_sandbox_effect",
        "real_external_blocked",
        "unknown"
      ]
    },
    "SchemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "Payload": true,
    "PayloadHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
